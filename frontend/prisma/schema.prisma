generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  password    String?
  institution String?
  createdAt   DateTime @default(now())
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  age       Int?
  gender    String?
  userId    String
  createdAt DateTime @default(now())

  records     EEGRecord[]
  predictions Prediction[]
}

model EEGRecord {
  id        String   @id @default(cuid())
  fileName  String
  filePath  String
  patientId String
  userId    String
  createdAt DateTime @default(now())

 patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Prediction {
  id         String   @id @default(cuid())
  patientId  String
  filePath   String
  prediction String
  confidence Float
  createdAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}
